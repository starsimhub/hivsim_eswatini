################################################################################
## Allen Roberts + Adam Akullian
## Compare simulation results across scenarios
## Uses summary outputs computed for each scenario across simulation runs
## Saves a dataset (scenario_comparison.RData) and plots (scenario_comparison_plots.pdf)
################################################################################
setwd("C:\\Users\\adamak\\Dropbox (IDM)\\GitHub\\EMOD_eswatini\\eSwatini2")
rm(list = ls())
# Libraries
library(ggplot2)
library(tidyverse)
library(viridisLite)
library(parallel)
library(foreach)
library(doParallel)
## Plot settings
theme_set(theme_classic())
## Suppress uninformative warnings
options(dplyr.summarise.inform=F)
## Function to combine results after parallel processing
comb <- function(x, ...) {
mapply(rbind,x,...,SIMPLIFY=FALSE)
}
## Set up parallels
numCores <- detectCores()
registerDoParallel(numCores)
## Output directory - where scenario results are stored
output_dir <- "Scenarios_PEPFAR\\Eswatini_PEPFAR_LANCET_baseinf_incarteff_incmceffic_age015_v2\\Output"
## Suite name. This example assumes that all the scenario results are located within the
## same suite, but it ideally would allow arbitrary specification of
## simulations (eg, across suites, or only certain runs within a given suite)
suite_name <- "Eswatini_PEPFAR_LANCET_baseinf_incarteff_incmceffic_age015_v2"
## Identify scenarios for a given suite
## In this test example, they are stored locally, but
## they could be located on COMPS
scenarios <- data.frame("name" = list.dirs(file.path(output_dir, suite_name), full.names = FALSE, recursive = FALSE))
#########################################################################################################################
## For each scenario, compute summary statistics and return outputs
#########################################################################################################################
outputs <- foreach(i=1:nrow(scenarios), .combine = 'comb', .multicombine = TRUE) %dopar% {
library(ggplot2)
library(tidyverse)
library(viridisLite)
library(parallel)
library(foreach)
library(doParallel)
scenario_name <- scenarios$name[i]
## Load outputs
load(file.path(output_dir, suite_name, scenario_name, "scenario_summary.RData"))
## population
pop <- outputs$pop %>%
group_by(year) %>%
summarise(mean = mean(pop),
median = median(pop),
lower = quantile(pop, probs = 0.025),
upper = quantile(pop, probs = 0.975)) %>%
mutate(scenario = scenario_name)
deaths_allages <- outputs$deaths_allages %>%
group_by(year) %>%
summarise(mean = mean(HIVdeaths),
median = median(HIVdeaths),
lower = quantile(HIVdeaths, probs = 0.025),
upper = quantile(HIVdeaths, probs = 0.975)) %>%
mutate(scenario = scenario_name)
#
## deaths under 15yrs
deaths_u15 <- outputs$deaths_u15 %>%
group_by(year) %>%
summarise(mean = mean(HIVdeaths),
median = median(HIVdeaths),
lower = quantile(HIVdeaths, probs = 0.025),
upper = quantile(HIVdeaths, probs = 0.975)) %>%
mutate(scenario = scenario_name)
#
## new infections all ages
newinf_allages <- outputs$newinf_allages %>%
group_by(year) %>%
summarise(mean = mean(new_infections),
median = median(new_infections),
lower = quantile(new_infections, probs = 0.025),
upper = quantile(new_infections, probs = 0.975)) %>%
mutate(scenario = scenario_name)
#
## new infections under 15yrs
newinf_u15 <- outputs$newinf_u15 %>%
group_by(year) %>%
summarise(mean = mean(new_infections),
median = median(new_infections),
lower = quantile(new_infections, probs = 0.025),
upper = quantile(new_infections, probs = 0.975)) %>%
mutate(scenario = scenario_name)
## on ART all ages
onART_allages <- outputs$onART_allages %>%
group_by(year) %>%
summarise(mean = mean(on_art),
median = median(on_art),
lower = quantile(on_art, probs = 0.025),
upper = quantile(on_art, probs = 0.975)) %>%
mutate(scenario = scenario_name)
#
## Infections all ages
plhiv_allages <- outputs$plhiv_allages %>%
group_by(year) %>%
summarise(mean = mean(Infected),
median = median(Infected),
lower = quantile(Infected, probs = 0.025),
upper = quantile(Infected, probs = 0.975)) %>%
mutate(scenario = scenario_name)
## Prevalence, ages 15-49, by gender
prev_adults_gender <- outputs$prev_adults_gender %>%
group_by(gender, year) %>%
summarise(prev_mean = mean(prev),
prev_median = median(prev),
prev_lower = quantile(prev, probs = 0.025),
prev_upper = quantile(prev, probs = 0.975)) %>%
mutate(scenario = scenario_name)
## Prevalence by age and gender
prev_age_gender <- outputs$prev_age_gender %>%
group_by(gender, age_group, year) %>%
summarise(prev_mean = mean(prev),
prev_median = median(prev),
prev_lower = quantile(prev, probs = 0.025),
prev_upper = quantile(prev, probs = 0.975)) %>%
mutate(scenario = scenario_name)
## Incidence, adults 15-49, by gender
inc_adults_gender <- outputs$inc_adults_gender %>%
group_by(gender, year) %>%
summarise(inc_mean = mean(inc),
inc_median = median(inc),
inc_lower = quantile(inc, probs = 0.025),
inc_upper = quantile(inc, probs = 0.975)) %>%
mutate(scenario = scenario_name)
## Incidence, by age and gender
inc_age_gender <- outputs$inc_age_gender %>%
group_by(age_group, gender, year) %>%
summarise(inc_mean = mean(inc),
inc_median = median(inc),
inc_lower = quantile(inc, probs = 0.025),
inc_upper = quantile(inc, probs = 0.975)) %>%
mutate(scenario = scenario_name)
## Incidence, by age group 3 and gender
inc_age_3_gender <- outputs$inc_age_3_gender %>%
group_by(age_group_3, gender, year) %>%
summarise(inc_mean = mean(inc),
inc_median = median(inc),
inc_lower = quantile(inc, probs = 0.025),
inc_upper = quantile(inc, probs = 0.975)) %>%
mutate(scenario = scenario_name)
# # Infections averted - cumulative infections scenario - cumulative infections baseline / cumulative infections scenario
# inf_averted_age_gender_runnum <- outputs$cum_infections_age %>%
#   select(run_num, year,Gender,Population, cum_infections) %>%
#   mutate(scenario = scenario_name) %>%
#   group_by(run_num, year,Gender,scenario) %>%
#   summarise(Population=sum(Population),cum_infections=sum(cum_infections)) %>%
inf_averted_gender <- outputs$cum_infections_gender %>%
group_by(gender, year) %>%
summarise(cuminc_mean = mean(cum_infections),
cuminc_median = median(cum_infections),
cuminc_lower = quantile(cum_infections, probs = 0.025),
cuminc_upper = quantile(cum_infections, probs = 0.975)) %>%
mutate(scenario = scenario_name)
inf_averted_age_gender <- outputs$cum_infections_age %>%
group_by(gender, age_group, year) %>%
summarise(cuminc_mean = mean(cum_infections),
cuminc_median = median(cum_infections),
cuminc_lower = quantile(cum_infections, probs = 0.025),
cuminc_upper = quantile(cum_infections, probs = 0.975)) %>%
mutate(scenario = scenario_name)
mortality_adults_gender <- outputs$mortality_adults_gender %>%
group_by(gender, year) %>%
summarise(mort_mean = mean(mort_rate),
mort_median = median(mort_rate),
mort_lower = quantile(mort_rate, probs = 0.025),
mort_upper = quantile(mort_rate, probs = 0.975)) %>%
mutate(scenario = scenario_name)
deaths_averted_gender <- outputs$cum_mort_gender %>%
group_by(gender, year) %>%
summarise(cumdeaths_mean = mean(cum_mort),
cumdeaths_median = median(cum_mort),
cumdeaths_lower = quantile(cum_mort, probs = 0.025),
cumdeaths_upper = quantile(cum_mort, probs = 0.975)) %>%
mutate(scenario = scenario_name)
art_age_gender <- outputs$art_adults_age_gender %>%
group_by(age_group, gender, year) %>%
summarise(artcov_mean = mean(art_cov),
artcov_median = median(art_cov),
artcov_lower = quantile(art_cov, probs = 0.025, na.rm=T),
artcov_upper = quantile(art_cov, probs = 0.975, na.rm=T)) %>%
mutate(scenario = scenario_name)
return(list("prev_adults_gender" = prev_adults_gender,
"prev_age_gender" = prev_age_gender,
"inc_adults_gender" = inc_adults_gender,
"inc_age_gender"=inc_age_gender,
"inc_age_3_gender"=inc_age_3_gender,
"inf_averted_gender"=inf_averted_gender,
"inf_averted_age_gender"=inf_averted_age_gender,
#              "inf_averted_age_gender_runnum" =inf_averted_age_gender_runnum
"mortality_adults_gender"=mortality_adults_gender,
"deaths_averted_gender"=deaths_averted_gender,
"art_age_gender"=art_age_gender,
"pop" = pop,
"deaths_allages"=deaths_allages,
"newinf_allages"=newinf_allages,
"plhiv_allages"=plhiv_allages,
"deaths_u15"=deaths_u15,
"newinf_u15"=newinf_u15,
"onART_allages"=onART_allages
))
}
## Save
save(outputs, file = file.path(output_dir, suite_name, "scenario_comparison.RData"))
