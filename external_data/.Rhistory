prevalence <- read.csv(paste0('./', infileprev, '.csv'))
prevalence$Age <- prevalence$start.age
prevalence$age_group = paste0(prevalence$Age,"-",prevalence$Age+4)
table(prevalence$Gender)
prevalence$gender[prevalence$Gender==0] <- "Men"
prevalence$gender[prevalence$Gender==1] <- "Women"
prevalence$year=prevalence$Year
prevalence <- subset(prevalence, Age<50)
head(prevalence)
infileprev <- "SWAZILAND_nationalprevalence_bothgenders"
prevalence.bothgenders <- read.csv(paste0('./', infileprev, '.csv'))
prevalence.bothgenders$gender[prevalence.bothgenders$Gender==0] <- "Men"
prevalence.bothgenders$gender[prevalence.bothgenders$Gender==1] <- "Women"
prevalence.bothgenders$gender[prevalence.bothgenders$Gender==2] <- "Adults 15-49"
head(prevalence.bothgenders)
#Bring in ART coverage data
infile1 <- "SWAZILAND_calibration_nationalARTprevalence_2021"
artdata <- read.csv(paste0('./', infile1, '.csv'))
artdata$Agecat <- artdata$AgeBin
artdata$ART_coverage <- artdata$NationalARTPrevalence
labs <- c("1" = "Women", "0" = "Men")
#Incidence by scenario
table(outputs$inc_adults_gender$scenario)
print(subset(outputs$inc_adults_gender, year>2000) %>%
ggplot(aes(x = year, y = inc_mean)) +
geom_line(aes(color = factor(scenario)), linewidth=1) +
geom_ribbon(aes(ymin = inc_lower , ymax = inc_upper , fill = factor(scenario)), alpha = 0.3, show.legend = FALSE) +
scale_color_hue(guide = guide_legend(title = ""), labels=labels) +
#scale_fill_manual() +
#scale_y_continuous(expand = c(0,0), breaks=seq(0,2,0.5), limits=c(0,2)) +
scale_x_continuous(breaks = seq(2000,2050,10), limits=c(2000, 2049),expand = c(0,0)) +
labs(x = "Year", y = "Incidence (per 100 py)") +
facet_wrap(~gender) +
ggtitle("Incidence among adults age 15-49") +
theme_bw(base_size=24) +
theme(legend.position="bottom") +
theme(strip.background = element_rect(colour="black", fill="white"))+
theme(panel.grid.major = element_blank(),
panel.grid.minor = element_blank(),
panel.border = element_rect(colour = "black"))
)
